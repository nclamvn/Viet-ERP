/// Khách hàng
model Customer {
  id       String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code     String @unique @db.VarChar(20)
  name     String @db.VarChar(500)
  country  String? @db.VarChar(50)
  currency String  @default("USD") @db.VarChar(3)

  // Pricing profile
  pricingProfile PricingProfile @default(new_customer) @map("pricing_profile")
  overheadPct    Decimal        @default(20) @map("overhead_pct") @db.Decimal(5, 2)
  profitPct      Decimal        @default(10) @map("profit_pct") @db.Decimal(5, 2)

  // Contacts
  primaryContact String? @map("primary_contact") @db.VarChar(200)
  email          String? @db.VarChar(200)
  phone          String? @db.VarChar(50)

  // Pipeline
  status CustomerStatus @default(active)

  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  larkRecordId String?   @map("lark_record_id") @db.VarChar(50)

  // Relations
  contacts       Contact[]
  quotations     Quotation[]
  costingHistories CostingHistory[]

  @@map("customers")
}

/// Liên hệ
model Contact {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  customerId String?  @map("customer_id") @db.Uuid
  customer   Customer? @relation(fields: [customerId], references: [id])
  fullName   String   @map("full_name") @db.VarChar(200)
  title      String?  @db.VarChar(100)
  email      String?  @db.VarChar(200)
  phone      String?  @db.VarChar(50)
  isPrimary  Boolean  @default(false) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("contacts")
}

/// Báo giá (Quotations)
model Quotation {
  id         String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  quoteNo    String  @unique @map("quote_no") @db.VarChar(30)
  customerId String? @map("customer_id") @db.Uuid
  customer   Customer? @relation(fields: [customerId], references: [id])

  // Sản phẩm
  itemId          String?  @map("item_id") @db.Uuid
  item            Item?    @relation(fields: [itemId], references: [id])
  itemDescription String?  @map("item_description") @db.Text
  quantity        Decimal? @db.Decimal(10, 2)
  weightPerUnit   Decimal? @map("weight_per_unit") @db.Decimal(10, 4)
  totalWeight     Decimal? @map("total_weight") @db.Decimal(12, 4)

  // Giá
  productionCostVnd Decimal? @map("production_cost_vnd") @db.Decimal(15, 2)
  sellPriceVnd      Decimal? @map("sell_price_vnd") @db.Decimal(15, 2)
  sellPriceUsd      Decimal? @map("sell_price_usd") @db.Decimal(12, 2)
  pricePerKgVnd     Decimal? @map("price_per_kg_vnd") @db.Decimal(12, 2)
  pricePerKgUsd     Decimal? @map("price_per_kg_usd") @db.Decimal(10, 2)

  // Trạng thái
  status QuotationStatus @default(draft)

  validUntil    DateTime? @map("valid_until") @db.Date
  notes         String?   @db.Text
  costBreakdown Json?     @map("cost_breakdown") @db.JsonB

  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  larkRecordId String?   @map("lark_record_id") @db.VarChar(50)

  @@map("quotations")
}

