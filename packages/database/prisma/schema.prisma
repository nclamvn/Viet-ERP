/// Yêu cầu mua hàng
model PurchaseRequest {
  id          String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  prNo        String                 @unique @map("pr_no") @db.VarChar(30)
  requestedBy String?                @map("requested_by") @db.VarChar(100)
  approvedBy  String?                @map("approved_by") @db.VarChar(100)
  status      PurchaseRequestStatus  @default(draft)
  workOrderRef String?               @map("work_order_ref") @db.VarChar(50)
  requiredDate DateTime?             @map("required_date") @db.Date
  remarks      String?               @db.Text
  createdAt    DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  larkRecordId String?               @map("lark_record_id") @db.VarChar(50)

  // Relations
  items PurchaseRequestItem[]

  @@map("purchase_requests")
}

/// Chi tiết yêu cầu mua hàng
model PurchaseRequestItem {
  id           String                     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  prId         String                     @map("pr_id") @db.Uuid
  pr           PurchaseRequest            @relation(fields: [prId], references: [id], onDelete: Cascade)
  itemId       String?                    @map("item_id") @db.Uuid
  itemCode     String?                    @map("item_code") @db.VarChar(50)
  itemName     String?                    @map("item_name") @db.VarChar(500)
  qty          Decimal                    @db.Decimal(15, 4)
  uom          String?                    @db.VarChar(20)
  requiredDate DateTime?                  @map("required_date") @db.Date
  status       PurchaseRequestItemStatus  @default(pending)
  supplier     String?                    @db.VarChar(200)
  poNumber     String?                    @map("po_number") @db.VarChar(50)
  remarks      String?                    @db.Text

  @@map("purchase_request_items")
}

// ============================================================
// 6. COSTING — Lịch sử tính giá (AI Copilot output)
// ============================================================

/// Lịch sử tính giá
model CostingHistory {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  projectName     String?  @map("project_name") @db.VarChar(200)
  customerId      String?  @map("customer_id") @db.Uuid
  customer        Customer? @relation(fields: [customerId], references: [id])
  itemDescription String?  @map("item_description") @db.Text

  // Input
  drawingFilePath String?  @map("drawing_file_path") @db.Text
  totalWeightKg   Decimal? @map("total_weight_kg") @db.Decimal(12, 4)
  quantity        Int?
  surfaceFinish   String?  @map("surface_finish") @db.VarChar(30)

  // Output
  materialCost     Decimal? @map("material_cost") @db.Decimal(15, 2)
  fabricationCost  Decimal? @map("fabrication_cost") @db.Decimal(15, 2)
  surfaceCost      Decimal? @map("surface_cost") @db.Decimal(15, 2)
  packagingFobCost Decimal? @map("packaging_fob_cost") @db.Decimal(15, 2)
  productionCost   Decimal? @map("production_cost") @db.Decimal(15, 2)
  overhead         Decimal? @db.Decimal(15, 2)
  profit           Decimal? @db.Decimal(15, 2)
  sellPriceVnd     Decimal? @map("sell_price_vnd") @db.Decimal(15, 2)
  sellPriceUsd     Decimal? @map("sell_price_usd") @db.Decimal(12, 2)
  pricePerKg       Decimal? @map("price_per_kg") @db.Decimal(10, 2)

  // Full breakdown
  bomData       Json? @map("bom_data") @db.JsonB
  costBreakdown Json? @map("cost_breakdown") @db.JsonB

  // Pricing profile used
  pricingProfile String?  @map("pricing_profile") @db.VarChar(30)
  exchangeRate   Decimal  @default(24500) @map("exchange_rate") @db.Decimal(10, 2)

  calculatedBy String   @default("ai_copilot") @map("calculated_by") @db.VarChar(50)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  larkRecordId String?  @map("lark_record_id") @db.VarChar(50)

  @@map("costing_history")
}

// ============================================================
// 7. LARK SYNC — Bảng theo dõi đồng bộ
// ============================================================

/// Log đồng bộ Lark
model LarkSyncLog {
  id           String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tableName    String        @map("table_name") @db.VarChar(100)
  recordId     String        @map("record_id") @db.Uuid
  larkRecordId String?       @map("lark_record_id") @db.VarChar(50)
  direction    SyncDirection
  status       SyncStatus    @default(success)
  payload      Json?         @db.JsonB
  errorMessage String?       @map("error_message") @db.Text
  syncedAt     DateTime      @default(now()) @map("synced_at") @db.Timestamptz

  @@index([tableName, recordId], map: "idx_sync_table")
  @@map("lark_sync_log")
}
