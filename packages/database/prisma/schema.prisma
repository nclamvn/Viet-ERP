/// Trạm sản xuất (Workstations)
model Workstation {
  id                 String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name               String   @unique @db.VarChar(200)
  description        String?  @db.Text
  hourRate           Decimal  @default(0) @map("hour_rate") @db.Decimal(12, 2)
  productionCapacity Int      @default(1) @map("production_capacity")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  operations    Operation[]
  bomOperations BomOperation[]
  jobCards      JobCard[]

  @@map("workstations")
}

/// Công đoạn (Operations)
model Operation {
  id              String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name            String      @unique @db.VarChar(200)
  workstationId   String?     @map("workstation_id") @db.Uuid
  workstation     Workstation? @relation(fields: [workstationId], references: [id])
  defaultTimeMins Int         @default(0) @map("default_time_mins")
  description     String?     @db.Text
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  bomOperations BomOperation[]
  jobCards      JobCard[]

  @@map("operations")
}

/// BOM (Bill of Materials)
model Bom {
  id                String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bomNo             String   @unique @map("bom_no") @db.VarChar(30)
  itemId            String   @map("item_id") @db.Uuid
  item              Item     @relation(fields: [itemId], references: [id])
  quantity          Decimal  @default(1) @db.Decimal(10, 4)
  isActive          Boolean  @default(true) @map("is_active")
  isDefault         Boolean  @default(false) @map("is_default")
  withOperations    Boolean  @default(true) @map("with_operations")

  // Tính toán
  totalMaterialCost  Decimal @default(0) @map("total_material_cost") @db.Decimal(15, 2)
  totalOperationCost Decimal @default(0) @map("total_operation_cost") @db.Decimal(15, 2)
  totalCost          Decimal @default(0) @map("total_cost") @db.Decimal(15, 2)

  companyId   String?   @map("company_id") @db.Uuid
  company     Company?  @relation(fields: [companyId], references: [id])
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  submittedAt DateTime? @map("submitted_at") @db.Timestamptz
  larkRecordId String?  @map("lark_record_id") @db.VarChar(50)

  // Relations
  bomItems    BomItem[]
  bomOperations BomOperation[]
  workOrders  WorkOrder[]

  @@map("bom")
}

/// BOM Items (NVL trong BOM)
model BomItem {
  id        String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bomId     String  @map("bom_id") @db.Uuid
  bom       Bom     @relation(fields: [bomId], references: [id], onDelete: Cascade)
  itemId    String  @map("item_id") @db.Uuid
  item      Item    @relation(fields: [itemId], references: [id])
  qty       Decimal @db.Decimal(15, 4)
  uomCode   String? @map("uom") @db.VarChar(20)
  uomRef    Uom?    @relation(fields: [uomCode], references: [code])
  rate      Decimal @default(0) @db.Decimal(15, 2)
  amount    Decimal @default(0) @db.Decimal(15, 2)
  sortOrder Int     @default(0) @map("sort_order")
  isScrap   Boolean @default(false) @map("is_scrap")
  scrapPct  Decimal @default(0) @map("scrap_pct") @db.Decimal(5, 2)

  @@map("bom_items")
}

/// BOM Operations (Công đoạn trong BOM)
model BomOperation {
  id             String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bomId          String      @map("bom_id") @db.Uuid
  bom            Bom         @relation(fields: [bomId], references: [id], onDelete: Cascade)
  operationId    String      @map("operation_id") @db.Uuid
  operation      Operation   @relation(fields: [operationId], references: [id])
  workstationId  String?     @map("workstation_id") @db.Uuid
  workstation    Workstation? @relation(fields: [workstationId], references: [id])
  timeInMins     Decimal     @default(0) @map("time_in_mins") @db.Decimal(10, 2)
  hourRate       Decimal     @default(0) @map("hour_rate") @db.Decimal(12, 2)
  operatingCost  Decimal     @default(0) @map("operating_cost") @db.Decimal(15, 2)
  sortOrder      Int         @default(0) @map("sort_order")

  @@map("bom_operations")
}

/// Lệnh sản xuất (Work Orders)
model WorkOrder {
  id             String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  woNo           String          @unique @map("wo_no") @db.VarChar(30)
  bomId          String          @map("bom_id") @db.Uuid
  bom            Bom             @relation(fields: [bomId], references: [id])
  itemId         String          @map("item_id") @db.Uuid
  item           Item            @relation(fields: [itemId], references: [id])
  qtyToProduce   Decimal         @map("qty_to_produce") @db.Decimal(10, 4)
  qtyProduced    Decimal         @default(0) @map("qty_produced") @db.Decimal(10, 4)

  status WorkOrderStatus @default(draft)

  plannedStart DateTime? @map("planned_start") @db.Date
  plannedEnd   DateTime? @map("planned_end") @db.Date
  actualStart  DateTime? @map("actual_start") @db.Timestamptz
  actualEnd    DateTime? @map("actual_end") @db.Timestamptz

  // Kho
  sourceWarehouseId String?    @map("source_warehouse_id") @db.Uuid
  sourceWarehouse   Warehouse? @relation("SourceWarehouse", fields: [sourceWarehouseId], references: [id])
  wipWarehouseId    String?    @map("wip_warehouse_id") @db.Uuid
  wipWarehouse      Warehouse? @relation("WipWarehouse", fields: [wipWarehouseId], references: [id])
  targetWarehouseId String?    @map("target_warehouse_id") @db.Uuid
  targetWarehouse   Warehouse? @relation("TargetWarehouse", fields: [targetWarehouseId], references: [id])

  // Đơn hàng liên kết
  salesOrderRef String? @map("sales_order_ref") @db.VarChar(50)
  customerName  String? @map("customer_name") @db.VarChar(200)

  companyId    String?   @map("company_id") @db.Uuid
  company      Company?  @relation(fields: [companyId], references: [id])
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  larkRecordId String?   @map("lark_record_id") @db.VarChar(50)

  // Relations
  jobCards JobCard[]

  @@index([status], map: "idx_wo_status")
  @@index([plannedStart, plannedEnd], map: "idx_wo_dates")
  @@map("work_orders")
}

/// Phiếu công việc (Job Cards)
model JobCard {
  id             String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  jobNo          String        @unique @map("job_no") @db.VarChar(30)
  workOrderId    String        @map("work_order_id") @db.Uuid
  workOrder      WorkOrder     @relation(fields: [workOrderId], references: [id])
  operationId    String        @map("operation_id") @db.Uuid
  operation      Operation     @relation(fields: [operationId], references: [id])
  workstationId  String?       @map("workstation_id") @db.Uuid
  workstation    Workstation?  @relation(fields: [workstationId], references: [id])

  qtyToProduce Decimal? @map("qty_to_produce") @db.Decimal(10, 4)
  qtyCompleted Decimal  @default(0) @map("qty_completed") @db.Decimal(10, 4)

  status JobCardStatus @default(open)

  startedAt   DateTime? @map("started_at") @db.Timestamptz
  completedAt DateTime? @map("completed_at") @db.Timestamptz
  timeInMins  Decimal   @default(0) @map("time_in_mins") @db.Decimal(10, 2)

  workerName String? @map("worker_name") @db.VarChar(200)
  remarks    String? @db.Text
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("job_cards")
}

