/// Kho hàng
model Warehouse {
  id              String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name            String        @unique @db.VarChar(200)
  code            String?       @db.VarChar(20)
  parentWarehouseId String?     @map("parent_warehouse") @db.Uuid
  parentWarehouse Warehouse?    @relation("WarehouseHierarchy", fields: [parentWarehouseId], references: [id])
  childWarehouses Warehouse[]   @relation("WarehouseHierarchy")
  isGroup         Boolean       @default(false) @map("is_group")
  companyId       String?       @map("company_id") @db.Uuid
  company         Company?      @relation(fields: [companyId], references: [id])
  warehouseType   WarehouseType @default(storage) @map("warehouse_type")
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  larkRecordId    String?       @map("lark_record_id") @db.VarChar(50)

  // Reverse relations
  stockLedgerEntries StockLedger[]
  sourceWorkOrders   WorkOrder[]   @relation("SourceWarehouse")
  wipWorkOrders      WorkOrder[]   @relation("WipWarehouse")
  targetWorkOrders   WorkOrder[]   @relation("TargetWarehouse")

  @@map("warehouses")
}

/// Tồn kho - Sổ cái
model StockLedger {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  itemId        String   @map("item_id") @db.Uuid
  item          Item     @relation(fields: [itemId], references: [id])
  warehouseId   String   @map("warehouse_id") @db.Uuid
  warehouse     Warehouse @relation(fields: [warehouseId], references: [id])
  postingDate   DateTime @default(dbgenerated("CURRENT_DATE")) @map("posting_date") @db.Date
  postingTime   DateTime @default(dbgenerated("CURRENT_TIME")) @map("posting_time") @db.Time
  qtyChange     Decimal  @map("qty_change") @db.Decimal(15, 4)
  valuationRate Decimal? @map("valuation_rate") @db.Decimal(15, 2)
  voucherType   String?  @map("voucher_type") @db.VarChar(50)
  voucherNo     String?  @map("voucher_no") @db.VarChar(50)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("stock_ledger")
}

