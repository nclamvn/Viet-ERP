generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [uuid_ossp(map: "uuid-ossp"), pg_trgm]
}

// ============================================================
// ENUMS
// ============================================================

enum ItemType {
  raw_material
  sub_assembly
  finished_good
  consumable
}

enum WarehouseType {
  storage
  wip
  finished
  shipping
  scrap
}

enum WorkOrderStatus {
  draft
  submitted
  in_progress
  completed
  cancelled
}

enum JobCardStatus {
  open
  in_progress
  completed
  cancelled
}

enum CustomerStatus {
  lead
  prospect
  active
  dormant
  churned
}

enum PricingProfile {
  ballymore
  new_customer
  dario_homy
  richmond
}

enum QuotationStatus {
  draft
  sent
  negotiating
  won
  lost
  expired
}

enum PurchaseRequestStatus {
  draft
  submitted
  approved
  ordered
  received
  cancelled
}

enum PurchaseRequestItemStatus {
  pending
  ordered
  received
  cancelled
}

enum SyncDirection {
  to_lark
  from_lark
}

enum SyncStatus {
  success
  failed
  pending
}

// ============================================================
// 1. MASTER DATA — Danh mục nền tảng
// ============================================================

/// Công ty
model Company {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code      String   @unique @db.VarChar(10)
  name      String   @db.VarChar(200)
  legalName String?  @map("legal_name") @db.VarChar(500)
  taxCode   String?  @map("tax_code") @db.VarChar(20)
  currency  String   @default("VND") @db.VarChar(3)
  country   String   @default("Vietnam") @db.VarChar(50)
  domain    String   @default("Manufacturing") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  warehouses Warehouse[]
  boms       Bom[]
  workOrders WorkOrder[]

  @@map("companies")
}

/// Nhóm vật tư (Item Groups) - Cấu trúc cây
model ItemGroup {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String   @unique @db.VarChar(200)
  parentGroup String?  @map("parent_group") @db.VarChar(200)
  isGroup     Boolean  @default(false) @map("is_group")
  level       Int      @default(0)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Lark Base sync
  larkRecordId String?   @map("lark_record_id") @db.VarChar(50)
  larkSyncedAt DateTime? @map("lark_synced_at") @db.Timestamptz

  // Relations
  items Item[]

  @@map("item_groups")
}

/// Đơn vị tính (UOM)
model Uom {
  id     String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code   String  @unique @db.VarChar(20)
  nameVi String? @map("name_vi") @db.VarChar(100)
  nameEn String? @map("name_en") @db.VarChar(100)

  // Relations
  items    Item[]
  bomItems BomItem[]

  @@map("uom")
}

/// Vật tư / Sản phẩm (Items) - Bảng chính
model Item {
  id       String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  itemCode String @unique @map("item_code") @db.VarChar(50)
  itemName String @map("item_name") @db.VarChar(500)

  // Relations to lookup tables
  itemGroupName String    @map("item_group") @db.VarChar(200)
  itemGroup     ItemGroup @relation(fields: [itemGroupName], references: [name])
  uomCode       String    @map("uom") @db.VarChar(20)
  uomRef        Uom       @relation(fields: [uomCode], references: [code])

  description String? @db.Text

  // Phân loại
  itemType             ItemType @default(raw_material) @map("item_type")
  maintainStock        Boolean  @default(true) @map("maintain_stock")
  includeInManufacturing Boolean @default(true) @map("include_in_manufacturing")

  // Giá
  valuationRate Decimal @default(0) @map("valuation_rate") @db.Decimal(15, 2)
  standardRate  Decimal @default(0) @map("standard_rate") @db.Decimal(15, 2)

  // Kho mặc định
  defaultWarehouse String? @map("default_warehouse") @db.Uuid

  // ERP cũ (MISA) mapping
  erpCode String? @map("erp_code") @db.VarChar(100)
  erpRef  String? @map("erp_ref") @db.VarChar(100)

  // Thông số kỹ thuật (cho NVL thép)
  materialGrade    String?  @map("material_grade") @db.VarChar(50)
  thicknessMm      Decimal? @map("thickness_mm") @db.Decimal(8, 2)
  outerDiameterMm  Decimal? @map("outer_diameter_mm") @db.Decimal(8, 2)
  widthMm          Decimal? @map("width_mm") @db.Decimal(8, 2)
  heightMm         Decimal? @map("height_mm") @db.Decimal(8, 2)
  lengthMm         Decimal? @map("length_mm") @db.Decimal(10, 2)
  weightPerMeter   Decimal? @map("weight_per_meter") @db.Decimal(10, 4)
  weightPerUnit    Decimal? @map("weight_per_unit") @db.Decimal(10, 4)

  // Metadata
  hsCode          String? @map("hs_code") @db.VarChar(20)
  countryOfOrigin String  @default("Vietnam") @map("country_of_origin") @db.VarChar(50)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Lark Base sync
  larkRecordId String?   @map("lark_record_id") @db.VarChar(50)
  larkSyncedAt DateTime? @map("lark_synced_at") @db.Timestamptz

  // Reverse relations
  stockLedgerEntries StockLedger[]
  boms               Bom[]
  bomItems           BomItem[]
  workOrders         WorkOrder[]
  quotations         Quotation[]

  @@index([itemCode], map: "idx_items_code")
  @@index([itemGroupName], map: "idx_items_group")
  @@index([itemType], map: "idx_items_type")
  @@index([erpCode], map: "idx_items_erp_code")
  @@map("items")
}

